# ─── Required ────────────────────────────────────────────────────────────────

# Telegram API credentials - get from https://my.telegram.org
API_ID=
API_HASH=

# Bot token - get from @BotFather
BOT_TOKEN=

# Directory for session file and persistent data
DATA_FOLDER=./data

# ─── Logging: Console ────────────────────────────────────────────────────────

# Log level for stdout (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Errors and above always go to stderr regardless of this setting
LOG_LEVEL_STDOUT=INFO

# ─── Logging: File ───────────────────────────────────────────────────────────

# Log level for file output
# LOG_LEVEL_FILE=INFO

# Path to log file - file logging is disabled if not set
# LOG_FILE_PATH=./data/bot.log

# Loguru rotation/retention/compression - only used if LOG_FILE_PATH is set
# See: https://loguru.readthedocs.io/en/stable/api/logger.html#loguru._logger.Logger.add
# LOG_ROTATION=500 MB
# LOG_RETENTION=1 month
# LOG_COMPRESSION=gz

# ─── Logging: Telegram ───────────────────────────────────────────────────────

# Channel ID to send logs to - Telegram logging is disabled if not set
# To get a channel ID: forward any message from it to @userinfobot
# LOG_CHANNEL=-100123456789

# Log level for Telegram output (defaults to INFO if LOG_CHANNEL is set)
# LOG_LEVEL_TELEGRAM=WARNING
